<!DOCTYPE html>
<html lang="ur" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Special For You 🫶🏼</title>
    <link href="https://fonts.googleapis.com/css2?family=Amiri:ital,wght@0,400;0,700;1,400&family=Noto+Nastaliq+Urdu:wght@400;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Noto Nastaliq Urdu', 'Amiri', serif;
            background: linear-gradient(135deg, #1d2671 0%, #c33764 50%, #ff7e5f 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow-x: hidden;
            position: relative;
            color: #ffffff;
            padding: 20px 10px;
        }

        /* Flower Canvas */
        #flower-canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 10;
        }

        /* Container Card */
        .card-container {
            position: relative;
            z-index: 2;
            width: 100%;
            max-width: 480px;
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 2px solid rgba(255, 215, 0, 0.5);
            border-radius: 30px;
            padding: 35px 25px;
            text-align: center;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4),
                        inset 0 0 20px rgba(255, 215, 0, 0.2);
            animation: fadeIn 1.2s ease-in-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Welcome Screen Styling */
        .special-title {
            font-size: 32px;
            font-weight: bold;
            color: #ffd700;
            text-shadow: 0 0 15px rgba(255, 215, 0, 0.8), 2px 2px 4px rgba(0,0,0,0.5);
            margin-bottom: 25px;
            letter-spacing: 1px;
            font-family: Arial, sans-serif;
        }

        .gift-icon {
            font-size: 60px;
            margin-bottom: 20px;
            animation: bounce 2s infinite;
        }

        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-15px); }
        }

        .action-btn {
            background: linear-gradient(135deg, #ff007f, #7928ca);
            color: #ffffff;
            border: none;
            padding: 15px 40px;
            font-size: 20px;
            font-weight: bold;
            font-family: Arial, sans-serif;
            border-radius: 50px;
            cursor: pointer;
            box-shadow: 0 10px 25px rgba(255, 0, 127, 0.5);
            transition: all 0.3s ease;
            outline: none;
            border: 2px solid rgba(255,255,255,0.6);
            display: inline-block;
        }

        .action-btn:hover {
            transform: scale(1.08);
            box-shadow: 0 15px 30px rgba(255, 0, 127, 0.8);
        }

        /* Wish Content (Initially Hidden) */
        #wishContent {
            display: none;
        }

        .islamic-symbol {
            font-size: 40px;
            color: #ffd700;
            text-shadow: 0 0 15px rgba(255, 215, 0, 0.8);
            margin-bottom: 10px;
        }

        .bismillah {
            font-family: 'Amiri', serif;
            font-size: 24px;
            color: #ffeaa7;
            margin-bottom: 15px;
        }

        .greeting-badge {
            background: linear-gradient(45deg, #ffd700, #ffa500);
            color: #1a1a2e;
            padding: 8px 22px;
            border-radius: 50px;
            display: inline-block;
            font-size: 22px;
            font-weight: bold;
            margin-bottom: 20px;
            box-shadow: 0 8px 20px rgba(255, 215, 0, 0.4);
        }

        .wish-box {
            background: rgba(0, 0, 0, 0.3);
            border-radius: 20px;
            padding: 20px 15px;
            margin-bottom: 20px;
            border-right: 4px solid #ffd700;
            border-left: 4px solid #ffd700;
        }

        .wish-text {
            font-size: 18px;
            line-height: 2.2;
            color: #f8f9fa;
        }

        .relationship-dua {
            background: rgba(255, 215, 0, 0.15);
            border: 1.5px dashed #ffd700;
            border-radius: 20px;
            padding: 18px 15px;
            margin-top: 15px;
        }

        .dua-title {
            font-size: 20px;
            color: #ffd700;
            font-weight: bold;
            margin-bottom: 8px;
            display: block;
        }

        .dua-text {
            font-size: 17px;
            line-height: 2.1;
            color: #ffeaa7;
        }

        .divider {
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 15px 0;
        }

        .divider::before, .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: linear-gradient(to right, transparent, #ffd700, transparent);
        }

        .divider-icon {
            padding: 0 10px;
            color: #ffd700;
        }
    </style>
</head>
<body>

    <canvas id="flower-canvas"></canvas>

    <div class="card-container">
        
        <div id="openScreen">
            <div class="special-title">Special for you 🫶🏼</div>
            <div class="gift-icon">🎁✨</div>
            <button class="action-btn" onclick="openSurprise()">Open 🎁</button>
        </div>

        <div id="wishContent">
            <div class="islamic-symbol">🕌 🌙</div>
            <div class="bismillah">بِسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيمِ</div>
            
            <div class="divider">
                <span class="divider-icon">✨ 🌸 ✨</span>
            </div>

            <div class="greeting-badge">
                🌅 صبح بخیر - Good Morning 🌅
            </div>

            <div class="wish-box">
                <p class="wish-text">
                    اللہ تعالیٰ aap ki is subah ko barkaton, khushiyon aur salamti se bhar de. Aap ka din hamesha muskurahat aur kamyabi se roshan rahe!
                </p>
            </div>

            <div class="relationship-dua">
                <span class="dua-title">💖 Humare Rishtay Ke Liye Khas Dua 🤲🏼</span>
                <p class="dua-text">
                    "Ya Allah! Humare is paak aur khubsurat rishtay ko hamesha ki muhabbat, izzat aur aitmaad se nawaz. Humari jodi ko har buri nazar se bacha aur humein hamesha ek doosre ka sahara aur khushi bana kar rakh. Aameen! ✨🤲🏼"
                </p>
            </div>
        </div>

    </div>

    <script>
        // Canvas Flower Animation
        const canvas = document.getElementById('flower-canvas');
        const ctx = canvas.getContext('2d');

        function resizeCanvas() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }
        window.addEventListener('resize', resizeCanvas);
        resizeCanvas();

        const flowers = [];
        const flowerIcons = ['🌸', '🌺', '🌹', '🌷', '🌼', '✨', '💖'];

        class Flower {
            constructor() {
                this.reset();
            }

            reset() {
                this.x = Math.random() * canvas.width;
                this.y = -20;
                this.size = Math.random() * 20 + 15;
                this.speedY = Math.random() * 2 + 1;
                this.speedX = Math.sin(Math.random() * Math.PI) * 1.5;
                this.rotation = Math.random() * 360;
                this.rotationSpeed = (Math.random() - 0.5) * 2;
                this.icon = flowerIcons[Math.floor(Math.random() * flowerIcons.length)];
                this.opacity = Math.random() * 0.7 + 0.3;
            }

            update() {
                this.y += this.speedY;
                this.x += Math.sin(this.y / 30) * 1;
                this.rotation += this.rotationSpeed;

                if (this.y > canvas.height + 20) {
                    this.reset();
                }
            }

            draw() {
                ctx.save();
                ctx.translate(this.x, this.y);
                ctx.rotate((this.rotation * Math.PI) / 180);
                ctx.globalAlpha = this.opacity;
                ctx.font = `${this.size}px Arial`;
                ctx.textAlign = 'center';
                ctx.textBaseline = 'middle';
                ctx.fillText(this.icon, 0, 0);
                ctx.restore();
            }
        }

        for (let i = 0; i < 40; i++) {
            const f = new Flower();
            f.y = Math.random() * canvas.height;
            flowers.push(f);
        }

        function animate() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            flowers.forEach(flower => {
                flower.update();
                flower.draw();
            });
            requestAnimationFrame(animate);
        }
        animate();

        // Open Button Function
        function openSurprise() {
            document.getElementById('openScreen').style.display = 'none';
            const wishBox = document.getElementById('wishContent');
            wishBox.style.display = 'block';
            wishBox.style.animation = 'fadeIn 1.5s ease-in-out';

            // Extra flowers shower on click
            for (let i = 0; i < 30; i++) {
                const f = new Flower();
                f.y = -10;
                flowers.push(f);
                if (flowers.length > 70) flowers.shift();
            }
        }
    </script>
</body>
</html>
